{
  "name": "run-and-notify",
  "version": "0.1.1",
  "description": "Execute a command and send the notification results via better-notify",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barbieri/run-and-notify.git"
  },
  "type": "module",
  "private": false,
  "license": "GPL-3.0-or-later",
  "keywords": [
    "cli",
    "notifications",
    "slack",
    "email",
    "automation",
    "monitoring",
    "run-and-notify"
  ],
  "engines": {
    "node": ">=26.4.0",
    "pnpm": ">=11.9.0"
  },
  "packageManager": "pnpm@11.9.0",
  "files": [
    "dist/bundle",
    "schemas",
    "examples",
    "config.example.json",
    ".env.example",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "run-and-notify": "dist/bundle/run-and-notify.mjs"
  },
  "scripts": {
    "build": "tsc && node scripts/build-cli.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "check": "biome check --error-on-warnings .",
    "check:fix": "biome check --write --error-on-warnings .",
    "format": "biome format --write .",
    "lint": "biome lint --error-on-warnings .",
    "qa": "run-p check build test typecheck",
    "run-and-notify": "node --import tsx src/run-and-notify.ts",
    "run-and-notify:bundle": "node dist/bundle/run-and-notify.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@betternotify/core": "1.0.0-beta.9",
    "@betternotify/email": "1.0.0-beta.6",
    "@betternotify/slack": "1.0.0-beta.5",
    "@betternotify/smtp": "1.0.0-beta.4",
    "@biomejs/biome": "^2.4.16",
    "@tsconfig/strictest": "^2.0.8",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "@types/turndown": "^5.0.6",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "4.1.8",
    "ajv": "8.20.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "handlebars": "^4.7.9",
    "husky": "^9.1.7",
    "lodash": "^4.18.1",
    "markdown-to-slack-blocks": "^1.5.0",
    "marked": "^18.0.5",
    "npm-run-all": "^4.1.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "turndown": "^7.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "yargs": "^18.0.0"
  }
}
